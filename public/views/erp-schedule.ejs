<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ERP Schedule - CybrixNova.com</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
    <style>
    table {
        border-collapse: collapse;
        width: 100%;
    }
    th, td {
        border: 1px solid #ccc;
        padding: 8px;
        text-align: center;
        height: 40px;
    }
    th {
        background-color: #f4f4f4;
    }
    .time-col {
        background-color: #fafafa;
        font-weight: bold;
        width: 100px;
    }
    .centered-box{
    background-color: silver;
    margin: auto;
    margin-bottom: 25px;
    max-width: 75%;
    font-size: 24px;
    text-align: center;
    opacity: 1;
    padding: 8px;
    top: 50;
    left: 50;
    color: black;
    font-family: 'ModernDos';
}
</style>
<body>
    <div class="centered-box">
        <table border="1">
        <tr>
            <th>Day</th>
            <th>12PM</th>
            <th>1PM</th>
            <th>2PM</th>
            <th>3PM</th>
            <th>4PM</th>
            <th>5PM</th>
            <th>6PM</th>
            <th>7PM</th>
            <th>8PM</th>
            <th>9PM</th>
            <th>10PM</th>
            <th>11PM</th>
            <th>12AM</th>
            <th>1AM</th>
        </tr>

        <% rows.forEach(row => { %>

        <tr>

        <td><%- row.day %></td>

        <td><%- row['1200'] %></td>
        <td><%- row['1300'] %></td>
        <td><%- row['1400'] %></td>
        <td><%- row['1500'] %></td>
        <td><%- row['1600'] %></td>
        <td><%- row['1700'] %></td>
        <td><%- row['1800'] %></td>
        <td><%- row['1900'] %></td>
        <td><%- row['2000'] %></td>
        <td><%- row['2100'] %></td>
        <td><%- row['2200'] %></td>
        <td><%- row['2300'] %></td>
        <td><%- row['0000'] %></td>
        <td><%- row['0100'] %></td>
        </form>
        </tr>

        <% }) %>

        </table>
</div>
</body>
</html>